# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git.

FLEETHUNT_HOST=https://app.fleethunt.in

# One token per bus. Add more BUS_n_ rows as you add buses.
BUS_1_VEHICLE_NO=XXXXXXXXXX
BUS_1_TOKEN=your-token-here

BUS_2_VEHICLE_NO=XXXXXXXXXX
BUS_2_TOKEN=your-token-here

BUS_3_VEHICLE_NO=XXXXXXXXXX
BUS_3_TOKEN=your-token-here

BUS_4_VEHICLE_NO=XXXXXXXXXX
BUS_4_TOKEN=your-token-here

RewriteEngine On

# /api/track  -> api/track.php
RewriteRule ^api/track/?$ api/track.php [L,QSA]

# /health -> api/health.php
RewriteRule ^health/?$ api/health.php [L,QSA]

# Never serve .env or json config files directly, even if misconfigured
<FilesMatch "\.(env|json)$">
    Require all denied
</FilesMatch>

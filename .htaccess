Options +FollowSymLinks -MultiViews
RewriteEngine On
RewriteBase /

# Block direct web access to sensitive directories and files
RewriteRule ^(src|cache)(/|$) - [F,L]

<FilesMatch "\.env$">
    Require all denied
</FilesMatch>

# Never serve .json config files directly
<FilesMatch "\.json$">
    Require all denied
</FilesMatch>

# Clean URL rewrites (without .php extension)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/track/?$ api/track.php [L,QSA]
RewriteRule ^health/?$ api/health.php [L,QSA]
